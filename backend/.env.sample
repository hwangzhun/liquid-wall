ADMIN_PASSWORD=changeme
JWT_SECRET=liquid-wall-secret-key
PORT=3001

# 默认昵称（表单自动预填）
VITE_DEFAULT_AUTHOR=

# 默认头像 URL（留空则不设置）
VITE_DEFAULT_AVATAR_URL=

# 腾讯云 COS 配置（请替换为真实值）
COS_REGION=ap-guangzhou
COS_BUCKET=your-bucket-name
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_PREFIX=posts/
# 预签名 URL 有效期（秒），默认为 1 年（31536000 秒）
COS_SIGNED_URL_EXPIRES=7200
# 可选：自定义访问域名（如 https://img.example.com），留空则使用默认 COS 域名
COS_CUSTOM_DOMAIN=